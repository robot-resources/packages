{
  "name": "@robot-resources/scraper-mcp",
  "mcpName": "io.github.robot-resources/scraper",
  "version": "0.1.2",
  "description": "MCP server for Scraper — context compression for AI agents",
  "author": "Robot Resources",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "bin": {
    "scraper-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@robot-resources/scraper": "^0.1.0"
  },
  "peerDependencies": {
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "@vitest/coverage-v8": "^2.1.0",
    "vitest": "^2.1.0",
    "zod": "^3.25.0"
  },
  "keywords": [
    "ai",
    "agents",
    "mcp",
    "scraper",
    "compression",
    "context",
    "llm",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robot-resources/packages.git",
    "directory": "scraper/packages/scraper-mcp"
  },
  "homepage": "https://robotresources.ai",
  "bugs": {
    "url": "https://github.com/robot-resources/robot-resources/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
