{
  "name": "@robot-resources/router",
  "version": "4.4.1",
  "description": "Robot Resources Router — in-process LLM routing for OpenClaw. Smart-selects the cheapest Anthropic model capable of each prompt. No daemon, no Python, runs inside the OC plugin process.",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./auto": "./auto.cjs",
    "./routing": "./lib/routing/index.js",
    "./telemetry": "./lib/telemetry.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "robot-resources-router": "./bin/setup.js"
  },
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run"
  },
  "files": [
    "index.js",
    "auto.cjs",
    "bin",
    "openclaw.plugin.json",
    "lib"
  ],
  "keywords": [
    "openclaw",
    "plugin",
    "robot-resources",
    "llm",
    "router",
    "ai",
    "cost-optimization",
    "anthropic",
    "model-selection"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robot-resources/packages.git",
    "directory": "router/packages/router"
  },
  "homepage": "https://robotresources.ai",
  "bugs": {
    "url": "https://github.com/robot-resources/packages/issues"
  },
  "license": "MIT",
  "author": "Robot Resources Team",
  "openclaw": {
    "extensions": [
      "./index.js"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  }
}
