{
  "name": "@robot-resources/router-mcp",
  "mcpName": "io.github.robot-resources/router",
  "version": "0.1.3",
  "description": "MCP server for Robot Resources Router — stats, config, and model comparison tools",
  "type": "module",
  "bin": {
    "router-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
